# Copy this file to .env and set your values.
# https://ai.google.dev/gemini-api/docs/api-key

# Required for all scripts that call Gemini.
GEMINI_API_KEY=

# Optional. Default in code: gemini-2.5-flash-lite if unset.
# GEMINI_MODEL=gemini-2.5-flash-lite

# Optional — only used by rag_agent.py and rag_agent_lc.py (FastEmbed / ONNX).
# Default in code: BAAI/bge-small-en-v1.5 if unset.
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# LangSmith (optional) — tracing for LangChain runs (*_lc.py).
# https://docs.smith.langchain.com/
# Uncomment and set LANGSMITH_API_KEY when you want traces sent to LangSmith.
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=training-traces
